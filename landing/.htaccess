<IfModule mod_headers.c>
  Header unset Cache-Control
  Header unset Pragma
  Header always set Cache-Control "private, no-cache, no-store, must-revalidate"
  Header always set Pragma "no-cache"
  Header always set Expires "Thu, 01 Jan 1970 00:00:00 GMT"
</IfModule>

<IfModule mod_deflate.c>
  SetOutputFilter DEFLATE
</IfModule>

# Custom error pages
ErrorDocument 404 /404.html
ErrorDocument 401 /401.html

# Clean URL rewrites (no .html extension)
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Skip existing files and directories
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Core pages
  RewriteRule ^about/?$                           /about.html [L]
  RewriteRule ^features/?$                        /features.html [L]
  RewriteRule ^pricing/?$                         /pricing.html [L]
  RewriteRule ^blog/?$                            /blog.html [L]
  RewriteRule ^contact/?$                         /contact.html [L]
  RewriteRule ^career/?$                          /career.html [L]
  RewriteRule ^integration/?$                     /integration.html [L]
  RewriteRule ^home-02/?$                         /home-02.html [L]
  RewriteRule ^privacy-policy/?$                  /privacy-policy.html [L]
  RewriteRule ^terms-condition/?$                 /terms-condition.html [L]
  RewriteRule ^404/?$                             /404.html [L]
  RewriteRule ^401/?$                             /401.html [L]

  # Utility pages
  RewriteRule ^utility-pages/style-guide/?$       /utility-pages/style-guide.html [L]
  RewriteRule ^utility-pages/changelog/?$         /utility-pages/changelog.html [L]
  RewriteRule ^utility-pages/license/?$           /utility-pages/license.html [L]

  # Blog posts — clean slugs AND direct filenames
  RewriteRule ^blog/how-to-build-processes.*$                    /blog-post-1.html [L]
  RewriteRule ^blog/creating-a-data-driven.*$                    /blog-post-2.html [L]
  RewriteRule ^blog/building-a-culture.*$                        /blog-post-3.html [L]
  RewriteRule ^blog/how-to-leverage-data.*$                      /blog-post-1.html [L]
  RewriteRule ^blog/creating-workflows.*$                        /blog-post-2.html [L]
  RewriteRule ^blog/designing-systems.*$                         /blog-post-3.html [L]
  RewriteRule ^blog/implementing-strategies.*$                   /blog-post-1.html [L]
  RewriteRule ^blog/optimizing-operations.*$                     /blog-post-2.html [L]
  RewriteRule ^blog/building-scalable.*$                         /blog-post-3.html [L]
  RewriteRule ^blog-post-1/?$                     /blog-post-1.html [L]
  RewriteRule ^blog-post-2/?$                     /blog-post-2.html [L]
  RewriteRule ^blog-post-3/?$                     /blog-post-3.html [L]

  # Integration detail pages — BOTH /integration/slug AND direct /slug forms
  RewriteRule ^integration/overlay/?$             /integration-detail-1.html [L]
  RewriteRule ^integration-detail-1/?$            /integration-detail-1.html [L]
  RewriteRule ^integration/frameflow/?$           /integration-frameflow.html [L]
  RewriteRule ^integration-frameflow/?$           /integration-frameflow.html [L]
  RewriteRule ^integration/dataflow/?$            /integration-dataflow.html [L]
  RewriteRule ^integration-dataflow/?$            /integration-dataflow.html [L]
  RewriteRule ^integration/blazelo/?$             /integration-blazelo.html [L]
  RewriteRule ^integration-blazelo/?$             /integration-blazelo.html [L]
  RewriteRule ^integration/bightly/?$             /integration-detail-2.html [L]
  RewriteRule ^integration-detail-2/?$            /integration-detail-2.html [L]
  RewriteRule ^integration/clodey/?$              /integration-detail-1.html [L]

  # Career detail — clean slug AND direct
  RewriteRule ^career/digital-marketing.*$        /career-detail.html [L]
  RewriteRule ^career/project-manager.*$          /career-detail.html [L]
  RewriteRule ^career/ux-ui-designer.*$           /career-detail.html [L]
  RewriteRule ^career-detail/?$                   /career-detail.html [L]
</IfModule>
