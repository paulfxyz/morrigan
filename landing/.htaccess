<IfModule mod_headers.c>
  Header unset Cache-Control
  Header unset Pragma
  Header always set Cache-Control "private, no-cache, no-store, must-revalidate"
  Header always set Pragma "no-cache"
  Header always set Expires "Thu, 01 Jan 1970 00:00:00 GMT"
</IfModule>

<IfModule mod_deflate.c>
  SetOutputFilter DEFLATE
</IfModule>

# Custom error pages
ErrorDocument 404 /404.html
ErrorDocument 401 /401.html

# Clean URL rewrites (no .html extension)
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Skip existing files and directories
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # ── Core pages ─────────────────────────────────────────
  RewriteRule ^about/?$                           /about.html [L]
  RewriteRule ^features/?$                        /features.html [L]
  RewriteRule ^pricing/?$                         /pricing.html [L]
  RewriteRule ^blog/?$                            /blog.html [L]
  RewriteRule ^contact/?$                         /contact.html [L]
  RewriteRule ^privacy-policy/?$                  /privacy-policy.html [L]
  RewriteRule ^terms-condition/?$                 /terms-condition.html [L]
  RewriteRule ^terms/?$                           /terms-condition.html [L]
  RewriteRule ^404/?$                             /404.html [L]
  RewriteRule ^401/?$                             /401.html [L]

  # ── New Morrígan pages ─────────────────────────────────
  RewriteRule ^security/?$                        /security.html [L]
  RewriteRule ^membership/?$                     /donate.html [L]
  RewriteRule ^donate/?$                          /donate.html [L]
  RewriteRule ^login/?$                           /login.html [L]
  RewriteRule ^signup/?$                          /signup.html [L]
  RewriteRule ^register/?$                        /signup.html [L]
  RewriteRule ^how-it-works/?$                    /how-it-works.html [L]
  RewriteRule ^how-it-works/.*$                   /how-it-works.html [L]

  # ── Utility pages ─────────────────────────────────────
  RewriteRule ^utility-pages/style-guide/?$       /utility-pages/style-guide.html [L]
  RewriteRule ^utility-pages/changelog/?$         /utility-pages/changelog.html [L]
  RewriteRule ^utility-pages/license/?$           /utility-pages/license.html [L]

  # ── Blog posts — clean slugs ──────────────────────────
  RewriteRule ^blog/why-your-digital-life.*$           /blog-post-1.html [L]
  RewriteRule ^blog/dead-mans-switch.*$                /blog-post-2.html [L]
  RewriteRule ^blog/zero-knowledge.*$                  /blog-post-3.html [L]
  RewriteRule ^blog/how-to-leverage-data.*$            /blog-post-1.html [L]
  RewriteRule ^blog/creating-workflows.*$              /blog-post-2.html [L]
  RewriteRule ^blog/designing-systems.*$               /blog-post-3.html [L]
  RewriteRule ^blog/implementing-strategies.*$         /blog-post-1.html [L]
  RewriteRule ^blog/optimizing-operations.*$           /blog-post-2.html [L]
  RewriteRule ^blog/building-scalable.*$               /blog-post-3.html [L]
  RewriteRule ^blog-post-1/?$                          /blog-post-1.html [L]
  RewriteRule ^blog-post-2/?$                          /blog-post-2.html [L]
  RewriteRule ^blog-post-3/?$                          /blog-post-3.html [L]
  # Catch all other /blog/* → blog listing
  RewriteRule ^blog/.*$                                /blog.html [L]

  # ── Backed-up pages: redirect to home ─────────────────
  RewriteRule ^home-02/?$                         / [R=301,L]
  RewriteRule ^career/?$                          /about.html [R=301,L]
  RewriteRule ^career/.*$                         /about.html [R=301,L]
  RewriteRule ^career-detail.*$                   /about.html [R=301,L]
  RewriteRule ^integration/?$                     /features.html [R=301,L]
  RewriteRule ^integration/.*$                    /features.html [R=301,L]
  RewriteRule ^integration-.*$                    /features.html [R=301,L]
</IfModule>
